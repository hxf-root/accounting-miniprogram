<view class="main-page">
  <!-- 顶部状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 顶栏：标题 + 日期 -->
  <view class="header">
    <view class="header-left">
      <text class="greeting">{{greeting}}</text>
      <text class="date">{{todayDate}}</text>
    </view>
    <view class="header-right">
      <text class="user-name">{{userName}}</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text class="loading-text">加载中...</text>
  </view>

  <scroll-view
    wx:else
    class="content-scroll"
    scroll-y
    show-scrollbar="{{false}}"
    bindrefresherrefresh="onRefresh"
    refresher-enabled
    refresher-triggered="{{refreshing}}"
  >
    <!-- ===== 记账模块卡片 ===== -->
    <view class="module-card glass-card" bindtap="goAccounting">
      <!-- 标题行 -->
      <view class="module-header">
        <view class="module-title-row">
          <text class="module-icon">📊</text>
          <text class="module-name">记账</text>
        </view>
        <text class="module-arrow">›</text>
      </view>

      <!-- 本月概览 -->
      <view class="module-body">
        <view class="stat-row monthly-stats">
          <view class="stat-item">
            <text class="stat-label">本月支出</text>
            <text class="stat-value stat-expense">¥{{monthly.expense}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">本月收入</text>
            <text class="stat-value stat-income">¥{{monthly.income}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">笔数</text>
            <text class="stat-value">{{monthly.count}}</text>
          </view>
        </view>

        <!-- 分类统计 -->
        <view wx:if="{{monthly.categories && monthly.categories.length > 0}}" class="category-strip">
          <view
            wx:for="{{monthly.categories}}"
            wx:key="index"
            class="category-tag"
          >
            <text class="cat-emoji">{{item.icon || '📦'}}</text>
            <text class="cat-name">{{item.name}}</text>
            <text class="cat-amount">¥{{item.amount}}</text>
          </view>
        </view>

        <view wx:else class="empty-hint">
          <text>本月暂无记录，点击开始记账</text>
        </view>
      </view>
    </view>

    <!-- ===== 健身模块卡片 ===== -->
    <view class="module-card glass-card" bindtap="goFitness">
      <view class="module-header">
        <view class="module-title-row">
          <text class="module-icon">💪</text>
          <text class="module-name">健身</text>
        </view>
        <text class="module-arrow">›</text>
      </view>

      <view class="module-body">
        <view class="stat-row today-stats">
          <view class="stat-item">
            <text class="stat-label">今日运动</text>
            <text class="stat-value">{{today.fitness_minutes || 0}}<text class="stat-unit">分钟</text></text>
          </view>
          <view class="stat-item">
            <text class="stat-label">消耗热量</text>
            <text class="stat-value">{{today.fitness_calories || 0}}<text class="stat-unit">千卡</text></text>
          </view>
        </view>

        <!-- 今日记账快照 -->
        <view class="snapshot-row">
          <view class="snapshot-item">
            <text class="snapshot-label">今日支出</text>
            <text class="snapshot-value snapshot-expense">¥{{today.expense || 0}}</text>
          </view>
          <view class="snapshot-item">
            <text class="snapshot-label">今日收入</text>
            <text class="snapshot-value snapshot-income">¥{{today.income || 0}}</text>
          </view>
        </view>
      </view>

      <view class="module-footer">
        <text class="footer-hint">点击查看详细统计</text>
      </view>
    </view>

    <!-- 底部安全区 -->
    <view class="bottom-safe"></view>
  </scroll-view>
</view>
