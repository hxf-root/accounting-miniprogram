/* 健身分析页面样式 */

.analytics-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.back-btn {
  font-size: 28rpx;
  color: #4ECDC4;
  padding: 10rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.placeholder {
  width: 80rpx;
}

/* 时间范围选择 */
.time-range {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.range-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.range-item.active {
  background: #4ECDC4;
  color: #fff;
  font-weight: 600;
}

/* 统计概览卡片 */
.stats-card {
  background: linear-gradient(135deg, #4ECDC4, #3DBDB4);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  color: white;
  box-shadow: 0 8rpx 30rpx rgba(78, 205, 196, 0.3);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx;
}

.stats-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.stats-value {
  font-size: 44rpx;
  font-weight: 700;
  font-family: 'DIN Alternate', sans-serif;
  margin-bottom: 4rpx;
}

.stats-label {
  font-size: 22rpx;
  opacity: 0.9;
}

/* 分区卡片 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 活动类型分布 */
.distribution-list {
  margin-top: 10rpx;
}

.distribution-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.distribution-item:last-child {
  border-bottom: none;
}

.distribution-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.distribution-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.distribution-icon .icon-text {
  font-size: 28rpx;
  color: #fff;
}

.distribution-name {
  font-size: 26rpx;
  color: #333;
}

.distribution-right {
  text-align: right;
}

.distribution-value {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.distribution-percent {
  font-size: 22rpx;
  color: #999;
}

/* 简单柱状图 */
.bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 200rpx;
  padding: 0 10rpx;
  margin-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
  justify-content: flex-end;
}

.bar-wrapper {
  width: 60rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.bar {
  width: 40rpx;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
  transition: height 0.5s ease;
}

.bar.minutes-bar {
  background: linear-gradient(180deg, #4ECDC4, #3DBDB4);
}

.bar.calories-bar {
  background: linear-gradient(180deg, #FF6B6B, #e85a5a);
}

.bar-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
  text-align: center;
}

/* 趋势图表 */
.trend-chart-area {
  margin-top: 10rpx;
}

.trend-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.trend-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.trend-date {
  width: 120rpx;
  font-size: 22rpx;
  color: #666;
  flex-shrink: 0;
}

.trend-bars {
  flex: 1;
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.trend-bar-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.trend-bar {
  width: 60rpx;
  border-radius: 6rpx 6rpx 0 0;
  min-height: 8rpx;
  transition: height 0.5s ease;
}

.trend-bar.minutes {
  background: linear-gradient(180deg, #4ECDC4, #3DBDB4);
}

.trend-bar.calories {
  background: linear-gradient(180deg, #FF6B6B, #e85a5a);
}

.trend-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 导出按钮 */
.btn-export {
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  width: 100%;
}

.btn-export::after {
  border: none;
}

.btn-export:active {
  background: #e8e8e8;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999;
}
