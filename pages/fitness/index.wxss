/* 健身主页样式 */

.fitness-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #4ECDC4, #3DBDB4);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  color: white;
  box-shadow: 0 8rpx 30rpx rgba(78, 205, 196, 0.3);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
}

.stats-date {
  font-size: 24rpx;
  opacity: 0.9;
}

.stats-body {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.stats-value {
  font-size: 40rpx;
  font-weight: 700;
  font-family: 'DIN Alternate', sans-serif;
  margin-bottom: 5rpx;
}

.stats-label {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 目标卡片 */
.goal-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.goal-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.goal-progress {
  font-size: 28rpx;
  color: #4ECDC4;
  font-weight: 600;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4ECDC4, #3DBDB4);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-fill.warn {
  background: linear-gradient(90deg, #f0b64c, #e7952d);
}

.progress-fill.done {
  background: linear-gradient(90deg, #20a66a, #1a8d5a);
}

.goal-footer {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goal-status {
  font-size: 24rpx;
  color: #20a66a;
}

.goal-status.warn {
  color: #e7952d;
}

.goal-status.done {
  color: #1a8d5a;
}

.goal-action {
  font-size: 24rpx;
  color: #4ECDC4;
  font-weight: 600;
}

/* 分区 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-action {
  font-size: 24rpx;
  color: #4ECDC4;
  font-weight: 500;
}

/* 快捷记录 */
.quick-activities {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.quick-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.icon-text {
  font-size: 40rpx;
  color: #fff;
}

.quick-name {
  font-size: 24rpx;
  color: #666;
}

/* 最近记录 */
.recent-list {
  margin-top: 10rpx;
}

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.recent-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.recent-info {
  flex: 1;
}

.recent-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.recent-time {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.recent-right {
  text-align: right;
}

.recent-minutes {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.recent-calories {
  display: block;
  font-size: 22rpx;
  color: #999;
}

/* 功能导航 */
.nav-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.nav-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.nav-name {
  font-size: 24rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: #999;
}
