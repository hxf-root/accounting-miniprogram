/* 登录页 */
.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 0 28px;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

/* 背景装饰圆 */
.bg-circle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.bg-circle-1 {
  width: 280px;
  height: 280px;
  background: linear-gradient(135deg, var(--accent-light), rgba(92,184,160,0.15));
  top: -80px;
  right: -60px;
}

.bg-circle-2 {
  width: 200px;
  height: 200px;
  background: linear-gradient(135deg, rgba(92,184,160,0.12), transparent);
  bottom: 10%;
  left: -80px;
}

.bg-circle-3 {
  width: 160px;
  height: 160px;
  background: linear-gradient(135deg, rgba(92,184,160,0.08), transparent);
  bottom: -40px;
  right: 20%;
}

/* Logo 区域 */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40px;
}

.logo-icon {
  font-size: 52px;
  line-height: 1;
  margin-bottom: 12px;
}

.logo-text {
  font-size: 28px;
  font-weight: 700;
  color: var(--text);
  letter-spacing: 2px;
}

.logo-sub {
  font-size: 13px;
  color: var(--text-muted);
  margin-top: 6px;
}

/* 登录卡片 */
.login-card {
  width: 100%;
  box-sizing: border-box;
  padding: 28px 24px;
}

.form-title {
  display: block;
  font-size: 20px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4px;
}

.form-subtitle {
  display: block;
  font-size: 13px;
  color: var(--text-muted);
  margin-bottom: 28px;
}

/* 输入框组 */
.input-group {
  margin-bottom: 18px;
}

.input-label {
  display: block;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 6px;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.8);
  border: 1px solid rgba(0,0,0,0.06);
  border-radius: 12px;
  padding: 0 12px;
}

.input-icon {
  font-size: 16px;
  margin-right: 8px;
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  height: 44px;
  padding: 0;
  font-size: 15px;
  color: var(--text);
  background: transparent;
  border: none;
  border-radius: 0;
}

.input-placeholder {
  color: var(--text-muted);
  font-size: 14px;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 46px;
  line-height: 46px;
  margin-top: 8px;
  font-size: 16px;
  letter-spacing: 4px;
  text-align: center;
}

.login-btn[disabled] {
  opacity: 0.6;
}

/* 切换登录/注册 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 22px;
  gap: 4px;
}

.switch-text {
  font-size: 13px;
  color: var(--text-muted);
}

.switch-link {
  font-size: 13px;
  color: var(--accent);
  font-weight: 500;
}
