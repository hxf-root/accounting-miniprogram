/* 明细页 - 使用全局 CSS 变量 */
page { background: var(--bg); }

.page { padding: 20rpx; padding-bottom: 140rpx; box-sizing: border-box; }

/* 统计行 */
.stats-row {
  display: flex;
  align-items: center;
  padding: 20rpx 8rpx;
  margin-bottom: 16rpx;
}

.stat-cell {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid rgba(0,0,0,0.05);
}
.stat-cell:last-child { border-right: none; }

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.stat-val {
  font-size: 34rpx;
  font-weight: 700;
  font-family: 'DIN Alternate', sans-serif;
}
.stat-val.expense { color: var(--expense); }
.stat-val.income { color: var(--income); }

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.filter-trigger {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 22rpx;
  background: rgba(0,0,0,0.04);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  flex: 1;
}

.filter-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  background: rgba(92,184,160,0.1);
  color: var(--accent);
  border-radius: 20rpx;
  font-size: 22rpx;
}

.filter-remove { padding: 2rpx; }

/* 账单滚动区 */
.bill-scroll {
  height: calc(100vh - 340rpx);
}

/* 日期分组 */
.bill-group { margin-bottom: 16rpx; }

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 4rpx;
}

.group-date { font-size: 26rpx; color: var(--text-secondary); font-weight: 500; }

.group-summary {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
}
.group-summary .income { color: var(--income); }
.group-summary .expense { color: var(--expense); }

/* 单条账单 */
.group-bills {
  background: var(--glass);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: var(--radius);
  border: 1rpx solid var(--glass-border);
  overflow: hidden;
}

.bill-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 20rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}
.bill-row:last-child { border-bottom: none; }

.bill-left { display: flex; align-items: center; flex: 1; overflow: hidden; }

.bill-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text { color: #fff; font-size: 28rpx; font-weight: 600; }

.bill-mid {
  flex: 1;
  margin: 0 14rpx;
  overflow: hidden;
}

.bill-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.bill-cat { font-size: 28rpx; font-weight: 600; color: var(--text); }

.bill-pay {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}
.pay-wechat { background: rgba(7,193,96,0.1); color: #07C160; }
.pay-alipay { background: rgba(22,119,255,0.1); color: #1677FF; }
.pay-cash { background: rgba(255,149,0,0.1); color: #FF9500; }
.pay-bankcard { background: rgba(88,86,214,0.1); color: #5856D6; }
.pay-credit { background: rgba(255,107,107,0.1); color: #FF6B6B; }

.bill-remark {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 2rpx;
}

.bill-time { font-size: 20rpx; color: var(--text-muted); }

.bill-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}

.bill-amount {
  font-size: 32rpx;
  font-weight: 700;
  font-family: 'DIN Alternate', sans-serif;
}
.bill-amount.expense { color: var(--expense); }
.bill-amount.income { color: var(--income); }

.delete-btn {
  font-size: 22rpx;
  color: var(--expense);
  padding: 4rpx 14rpx;
  border: 1rpx solid var(--expense);
  border-radius: 8rpx;
}

/* 筛选弹窗 */
.popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.35);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.popup-content {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 28rpx 32rpx;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  box-sizing: border-box;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.popup-close { font-size: 32rpx; color: var(--text-muted); padding: 8rpx; }

.filter-section { margin-bottom: 28rpx; }

.filter-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
  margin-bottom: 16rpx;
}

.filter-opts {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.filter-opt {
  padding: 14rpx 30rpx;
  background: rgba(0,0,0,0.04);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.filter-opt.active {
  background: rgba(92,184,160,0.12);
  color: var(--accent);
  font-weight: 600;
}

.date-range-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  font-size: 26rpx;
}

.date-picker-box {
  padding: 14rpx 24rpx;
  background: rgba(0,0,0,0.04);
  border-radius: 10rpx;
  color: var(--text);
  min-width: 180rpx;
  text-align: center;
}

.filter-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}

.filter-actions .btn-outline { flex: 1; }
.filter-actions .btn-primary { flex: 1; }

/* 列表底部 */
.list-footer {
  text-align: center;
  padding: 36rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}
