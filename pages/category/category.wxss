/* 分类管理页 - 使用全局 CSS 变量 */
page { background: var(--bg); }

.page { padding: 20rpx; padding-bottom: 140rpx; box-sizing: border-box; }

/* 类型切换 */
.type-switch {
  display: flex;
  background: var(--glass);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: var(--radius);
  border: 1rpx solid var(--glass-border);
  margin-bottom: 16rpx;
  overflow: hidden;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.3s;
}

.type-tab.active {
  color: #fff;
  background: linear-gradient(135deg, var(--accent), var(--accent-dark));
  font-weight: 600;
}

/* 分类列表 */
.cat-list { padding: 0 20rpx; }

.cat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}
.cat-item:last-child { border-bottom: none; }

.cat-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.cat-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.cat-icon-text { color: #fff; font-size: 30rpx; }

.cat-name {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
}

.cat-badge {
  font-size: 20rpx;
  color: var(--text-muted);
  background: rgba(0,0,0,0.04);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

.cat-actions { padding: 6rpx; }
.cat-del { font-size: 32rpx; padding: 10rpx; }

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--glass);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1rpx solid var(--glass-border);
}

.add-cat-btn { width: 100%; }

/* 添加分类弹窗 */
.popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.35);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.popup-content {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 28rpx 32rpx;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  box-sizing: border-box;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.popup-close { font-size: 32rpx; color: var(--text-muted); padding: 8rpx; }

.form-section { margin-bottom: 24rpx; }

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 14rpx;
}

.form-input {
  width: 100%;
  height: 76rpx;
  border: 2rpx solid rgba(0,0,0,0.06);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 图标网格 */
.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.icon-cell { display: flex; }

.icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  transition: transform 0.2s;
}

.icon-cell.selected .icon-wrap {
  transform: scale(1.12);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

/* 颜色网格 */
.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-cell { display: flex; }

.color-swatch {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.color-cell.selected .color-swatch {
  transform: scale(1.15);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.color-check { color: #fff; font-size: 24rpx; font-weight: 700; }

.form-actions { margin-top: 12rpx; }
.form-actions .btn-primary { width: 100%; }
