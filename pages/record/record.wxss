/* 记账页 - 使用全局 CSS 变量 */
page { background: var(--bg); }

.page {
  padding-bottom: 40rpx;
  background: var(--bg);
  min-height: 100vh;
}

/* 类型切换 */
.type-switch {
  display: flex;
  justify-content: center;
  padding: 30rpx;
  gap: 24rpx;
}

.type-btn {
  padding: 16rpx 64rpx;
  font-size: 32rpx;
  color: var(--text-muted);
  border-radius: 999rpx;
  background: rgba(0,0,0,0.03);
  transition: all 0.3s;
}

.type-btn.active {
  background: linear-gradient(135deg, var(--accent), var(--accent-dark));
  color: #fff;
  font-weight: 600;
}

/* 金额 */
.amount-area {
  text-align: center;
  padding: 30rpx 0 20rpx;
}

.amount-currency {
  font-size: 44rpx;
  color: var(--text);
  margin-right: 6rpx;
}

.amount-value {
  font-size: 80rpx;
  font-weight: 700;
  color: var(--text);
  font-family: 'DIN Alternate', sans-serif;
}

/* 分类网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding: 10rpx 0;
}

.category-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: calc((100% - 72rpx) / 4);
  transition: transform 0.2s;
}

.category-cell.selected { transform: scale(1.05); }

.cat-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.cat-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
}

.category-cell.selected .cat-name { color: var(--accent); font-weight: 600; }

/* 支付方式网格 */
.payment-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.payment-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 20rpx;
  border-radius: var(--radius);
  background: rgba(0,0,0,0.03);
  position: relative;
  min-width: 100rpx;
  flex: 1;
}

.payment-cell.selected { background: rgba(92,184,160,0.08); }

.pay-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid transparent;
}

.pay-name { font-size: 22rpx; color: var(--text-secondary); }

.pay-check {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 18rpx;
  text-align: center;
  line-height: 32rpx;
}

/* 日期/时间/备注 */
.meta-row {
  display: flex;
  gap: 32rpx;
  padding: 4rpx 0;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
}

.meta-text { color: var(--text); }
.meta-placeholder { color: var(--text-muted); }

.remark-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.remark-tag {
  padding: 10rpx 22rpx;
  background: rgba(0,0,0,0.04);
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 数字键盘 */
.numpad {
  padding: 12rpx 16rpx 32rpx;
}

.numpad-row {
  display: flex;
  height: 96rpx;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.numpad-key {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 12rpx;
  color: var(--text);
}

.numpad-key:active { background: rgba(0,0,0,0.06); }

.numpad-zero { flex: 2.2; }

.numpad-del { background: #ffe5e5; color: var(--expense); }
.numpad-action { font-size: 28rpx; color: var(--text-secondary); }
.numpad-confirm {
  background: linear-gradient(135deg, var(--accent), var(--accent-dark));
  color: #fff;
  font-size: 28rpx;
}
.numpad-confirm:active { opacity: 0.9; }

/* 备注弹窗 */
.popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.popup-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  width: 80%;
  max-width: 600rpx;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.popup-close { font-size: 32rpx; color: var(--text-muted); padding: 8rpx; }

.remark-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid rgba(0,0,0,0.06);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.popup-btn { width: 100%; }
