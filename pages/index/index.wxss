/* 记账首页 - 使用全局 CSS 变量 */
page { background: var(--bg); }

.page {
  padding: 20rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top));
  box-sizing: border-box;
}

/* 统计卡片 - 薄荷绿渐变覆盖 */
.stats-card {
  background: linear-gradient(135deg, #5cb8a0, #4aa38c);
  color: #fff;
  border: none;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.stats-month { font-size: 32rpx; font-weight: 700; }
.stats-subtitle { font-size: 24rpx; opacity: 0.85; }

.stats-body {
  display: flex;
  align-items: center;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.85;
  margin-bottom: 8rpx;
}

.stats-value {
  font-size: 40rpx;
  font-weight: 700;
  font-family: 'DIN Alternate', 'Helvetica Neue', sans-serif;
}

.stats-divider {
  width: 2rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.3);
}

/* 预算区域 */
.budget-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.budget-header .section-title { margin-bottom: 0; }

.budget-link {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 600;
}

.budget-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6rpx 0;
}
.budget-label { font-size: 24rpx; color: var(--text-secondary); }
.budget-value { font-size: 28rpx; font-weight: 700; color: var(--text); }

.budget-progress-track {
  width: 100%;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(0,0,0,0.06);
  overflow: hidden;
  margin-top: 10rpx;
}

.budget-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--accent), var(--accent-dark));
  transition: width 0.4s ease;
}

.budget-progress-fill.warn { background: linear-gradient(135deg, #f0b64c, #e7952d); }
.budget-progress-fill.over { background: linear-gradient(135deg, #ef6a6a, #d64f4f); }

.budget-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
}
.budget-hint.warn { color: #e7952d; }
.budget-hint.over { color: #d64f4f; }

.budget-empty { padding: 6rpx 0; }
.budget-empty-text { font-size: 24rpx; color: var(--text-muted); }

/* 饼图 */
.pie-chart-wrap {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.pie-chart {
  position: relative;
  width: 300rpx;
  height: 300rpx;
}

.pie-ring {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  mask: radial-gradient(transparent 56%, black 57%);
  -webkit-mask: radial-gradient(transparent 56%, black 57%);
}

.pie-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.pie-center-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.pie-center-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  font-family: 'DIN Alternate', sans-serif;
}

.chart-legend {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  padding: 12rpx 4rpx 0;
}

.legend-item {
  display: flex;
  align-items: center;
  background: rgba(0,0,0,0.03);
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.legend-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.legend-name { color: var(--text); margin-right: 8rpx; }
.legend-percent { color: var(--accent); font-weight: 600; }

/* 最近记录列表 */
.recent-list { margin-top: 8rpx; }

.bill-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}
.bill-item:last-child { border-bottom: none; }

.category-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-text { color: #fff; font-size: 30rpx; font-weight: 600; }

.bill-info {
  flex: 1;
  margin: 0 16rpx;
  overflow: hidden;
}

.bill-top {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.bill-category { font-size: 28rpx; font-weight: 600; color: var(--text); }

.payment-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  margin-left: 10rpx;
}
.payment-tag.wechat { background: rgba(7,193,96,0.1); color: #07C160; }
.payment-tag.alipay { background: rgba(22,119,255,0.1); color: #1677FF; }
.payment-tag.cash { background: rgba(255,149,0,0.1); color: #FF9500; }
.payment-tag.bankcard { background: rgba(88,86,214,0.1); color: #5856D6; }
.payment-tag.credit { background: rgba(255,107,107,0.1); color: #FF6B6B; }
.payment-tag.other { background: rgba(178,190,195,0.1); color: #B2BEC3; }

.bill-remark {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}

.bill-date { font-size: 22rpx; color: var(--text-muted); }

.bill-amount {
  font-size: 34rpx;
  font-weight: 700;
  font-family: 'DIN Alternate', sans-serif;
  white-space: nowrap;
}

.bottom-spacer { height: 160rpx; }
