<view class="settings-page">
  <!-- 顶部状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 顶栏 -->
  <view class="header">
    <text class="header-title">设置</text>
    <text class="header-subtitle">{{userName}}</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text class="loading-text">加载中...</text>
  </view>

  <scroll-view
    wx:else
    class="content-scroll"
    scroll-y
    show-scrollbar="{{false}}"
    bindrefresherrefresh="onRefresh"
    refresher-enabled
    refresher-triggered="{{refreshing}}"
  >
    <!-- ===== 统计概览卡片 ===== -->
    <view class="section-title">数据概览</view>
    <view class="glass-card overview-card">
      <view class="overview-row">
        <view class="overview-item">
          <text class="overview-label">总笔数</text>
          <text class="overview-value">{{stats.totalCount}}</text>
        </view>
        <view class="overview-item">
          <text class="overview-label">总支出</text>
          <text class="overview-value overview-expense">¥{{stats.totalExpense}}</text>
        </view>
        <view class="overview-item">
          <text class="overview-label">总收入</text>
          <text class="overview-value overview-income">¥{{stats.totalIncome}}</text>
        </view>
      </view>
    </view>

    <!-- ===== 月预算设置 ===== -->
    <view class="section-title">预算设置</view>
    <view class="glass-card">
      <view class="setting-row">
        <view class="setting-label-wrap">
          <text class="setting-icon">💰</text>
          <text class="setting-label">每月预算</text>
        </view>
        <view class="setting-input-wrap">
          <text class="setting-currency">¥</text>
          <input
            class="setting-input"
            type="digit"
            placeholder="不限制"
            placeholder-style="color:var(--text-muted);font-size:14px;"
            value="{{budget}}"
            bindinput="onBudgetInput"
            bindblur="onBudgetBlur"
          />
        </view>
      </view>
      <view wx:if="{{budget > 0 && stats.totalExpenseNum > 0}}" class="budget-bar-wrap">
        <view class="budget-bar">
          <view class="budget-fill" style="width: {{budgetPercent}}%;"></view>
        </view>
        <text class="budget-hint">本月已支出 {{stats.totalExpense}}，占预算 {{budgetPercent}}%</text>
      </view>
    </view>

    <!-- ===== 数据导入导出 ===== -->
    <view class="section-title">数据管理</view>
    <view class="glass-card">
      <view class="action-row" bindtap="onExport">
        <view class="action-left">
          <text class="action-icon">📤</text>
          <view class="action-text-wrap">
            <text class="action-label">导出数据</text>
            <text class="action-desc">备份账单和健身记录</text>
          </view>
        </view>
        <text class="action-arrow">›</text>
      </view>
      <view class="action-divider"></view>
      <view class="action-row" bindtap="goImport">
        <view class="action-left">
          <text class="action-icon">📥</text>
          <view class="action-text-wrap">
            <text class="action-label">导入数据</text>
            <text class="action-desc">从 JSON 或 CSV 恢复</text>
          </view>
        </view>
        <text class="action-arrow">›</text>
      </view>
    </view>

    <!-- ===== 危险操作 ===== -->
    <view class="section-title">危险区域</view>
    <view class="glass-card danger-card">
      <view class="action-row" bindtap="onClearData">
        <view class="action-left">
          <text class="action-icon danger-icon">🗑️</text>
          <view class="action-text-wrap">
            <text class="action-label action-label-danger">清空所有数据</text>
            <text class="action-desc">删除全部账单和健身记录，不可恢复</text>
          </view>
        </view>
        <text class="action-arrow">›</text>
      </view>
    </view>

    <!-- ===== 应用信息 ===== -->
    <view class="section-title">关于</view>
    <view class="glass-card about-card">
      <view class="about-row">
        <text class="about-label">应用名称</text>
        <text class="about-value">抱布记</text>
      </view>
      <view class="about-divider"></view>
      <view class="about-row">
        <text class="about-label">版本</text>
        <text class="about-value">1.0.0</text>
      </view>
      <view class="about-divider"></view>
      <view class="about-row">
        <text class="about-label">用户</text>
        <text class="about-value">{{userName}}</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-wrap">
      <button class="btn-outline logout-btn" bindtap="onLogout">退出登录</button>
    </view>

    <!-- 底部安全区 -->
    <view class="bottom-safe"></view>
  </scroll-view>

  <!-- ===== 清空确认弹窗 ===== -->
  <view wx:if="{{showClearModal}}" class="popup-mask" bindtap="hideClearModal">
    <view class="popup-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">确认清空</text>
      </view>
      <view class="modal-body">
        <text class="modal-icon">⚠️</text>
        <text class="modal-text">确定要清空所有数据吗？</text>
        <text class="modal-subtext">账单和健身记录将被永久删除，此操作不可撤销。</text>
      </view>
      <view class="modal-actions">
        <button class="btn-outline modal-btn" bindtap="hideClearModal">取消</button>
        <button class="btn-primary modal-btn" bindtap="confirmClearData">确认清空</button>
      </view>
    </view>
  </view>

  <!-- ===== 预算编辑弹窗 ===== -->
  <view wx:if="{{showBudgetModal}}" class="popup-mask" bindtap="hideBudgetModal">
    <view class="popup-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">设置月预算</text>
      </view>
      <view class="modal-body">
        <view class="budget-input-group">
          <text class="budget-input-currency">¥</text>
          <input
            class="budget-input"
            type="digit"
            placeholder="输入预算金额"
            placeholder-style="color:var(--text-muted);font-size:18px;"
            value="{{budgetEditValue}}"
            focus="{{true}}"
            bindinput="onBudgetEditInput"
          />
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn-outline modal-btn" bindtap="hideBudgetModal">取消</button>
        <button class="btn-primary modal-btn" bindtap="confirmBudget">保存</button>
      </view>
    </view>
  </view>
</view>
