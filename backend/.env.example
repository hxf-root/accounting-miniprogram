# 抱布记 后端配置
# 复制为 .env 后修改

# 服务端口
HOST=0.0.0.0
PORT=8089

# 数据库路径（相对路径或绝对路径）
DATABASE_URL=sqlite:///./baobaoji.db

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET_KEY=baobaoji-secret-key-change-in-production

# JWT 过期时间（小时，默认 720 即 30 天）
JWT_EXPIRE_HOURS=720

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
